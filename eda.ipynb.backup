    }
   ],
   "source": [
    "# ==================== FIGURE 3 — SKENARIO 1 (Train 204) ====================\n",
    "epochs = np.arange(1, 31)\n",
    "\n",
    "# Training loss per epoch — LR = 1e-2, Skenario 1\n",
    "vgg16_s1 = [881021376.8860, 39210217.8964, 1511385.7521, 133087.5031,\n",
    "            856.9256, 56.5307, 23.2779, 13.7768, 9.8312, 5.3893,\n",
    "            2.7787, 1.6650, 1.3490, 1.3129, 1.2648, 1.1995,\n",
    "            1.2207, 1.1785, 1.3298, 18.8878, 140.1001, 30.6807,\n",
    "            6.9602, 4.0409, 2.5181, 2.0978, 1.9916, 1.6910,\n",
    "            1.5188, 1.4621]\n",
    "\n",
    "resnet50_s1 = [1.3358, 1.0050, 0.8777, 0.9379, 1.1152, 0.6589,\n",
    "               0.4291, 0.3751, 0.3559, 0.3513, 0.2775, 0.2590,\n",
    "               0.4167, 0.2212, 0.1778, 0.1721, 0.2065, 0.2491,\n",
    "               0.1954, 0.1860, 0.1197, 0.1032, 0.0965, 0.1126,\n",
    "               0.1846, 0.2976, 0.1473, 0.0990, 0.0785, 0.0689]\n",
    "\n",
    "vit_s1 = [3.0240, 1.2774, 1.3330, 1.5026, 1.2380, 1.1970,\n",
    "          1.1323, 1.2028, 1.1946, 1.1378, 1.1579, 1.1446,\n",
    "          1.1472, 1.1063, 1.1250, 1.0248, 1.1394, 1.1133,\n",
    "          1.1155, 1.0890, 1.0945, 1.0525, 1.0095, 1.1007,\n",
    "          1.0500, 1.0213, 0.9083, 0.9052, 1.0559, 1.0347]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 6))\n",
    "ax.plot(epochs, vgg16_s1, 'o-', color='#D32F2F', linewidth=2, markersize=5, label='VGG16')\n",
    "ax.plot(epochs, resnet50_s1, 's-', color='#1976D2', linewidth=2, markersize=5, label='ResNet50')\n",
    "ax.plot(epochs, vit_s1, '^-', color='#388E3C', linewidth=2, markersize=5, label='ViT')\n",
    "ax.set_yscale('log')\n",
    "ax.set_xlabel('Epoch', fontweight='bold')\n",
    "ax.set_ylabel('Training Loss (log scale)', fontweight='bold')\n",
    "ax.set_title('Fig. 3a. Training Loss at LR = $10^{-2}$ — Skenario 1\\n(Train 204 / Val 26 / Test 26)', fontweight='bold')\n",
    "ax.legend(framealpha=0.9)\n",
    "ax.grid(True, linestyle='--', alpha=0.6)\n",
    "ax.set_xticks(epochs[::5])\n",
    "plt.tight_layout()\n",
    "plt.savefig('fig3a_trainloss_1e2_skenario1.png')\n",
    "plt.show()\n"
   ]
  },
