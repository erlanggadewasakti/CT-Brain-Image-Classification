    "ax.plot(epochs, vgg16_s2, 'o-', color='#D32F2F', linewidth=2, markersize=5, label='VGG16')\n",
    "ax.plot(epochs, resnet50_s2, 's-', color='#1976D2', linewidth=2, markersize=5, label='ResNet50')\n",
    "ax.plot(epochs, vit_s2, '^-', color='#388E3C', linewidth=2, markersize=5, label='ViT')\n",
    "ax.set_xlabel('Epoch', fontweight='bold')\n",
    "ax.set_ylabel('Validation Accuracy', fontweight='bold')\n",
    "ax.set_title('Fig. 4b. Validation Accuracy at LR = $10^{-4}$ — Scenario 2\\n(Val 52)', fontweight='bold')\n",
    "ax.legend(framealpha=0.9, loc='lower left')\n",
    "ax.grid(True, linestyle='--', alpha=0.6)\n",
